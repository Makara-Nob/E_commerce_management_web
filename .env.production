# ========================================================================
# 🏠 MENU SCANNER PRODUCTION CONFIGURATION
# ========================================================================

# Application Configuration
APP_NAME=menu-scanner
EXTERNAL_PORT=8888
PORT=8888
PM2_STARTUP=true

# ========================================================================
# 🔐 Git Configuration - GitHub with Personal Access Token
# ========================================================================
GIT_USERNAME=Phatmenghor
GIT_PASSWORD=
GIT_REPO_URL=https://github.com/Phatmenghor/menu-scanner-frontend-owner.git
GIT_BRANCH=development

# ========================================================================
# 🌐 Next.js Environment Variables
# ========================================================================
NODE_ENV=production
NEXT_PUBLIC_NODE_ENV=development

# ========================================================================
# 🔗 API Configuration - NGINX PROXY SETUP
# Frontend calls: http://152.42.219.13:8443/api/* → nginx → backend:9090
# ========================================================================
NEXT_PUBLIC_API_BASE_URL=http://152.42.219.13:8080
BACKEND_API_URL=http://152.42.219.13:8080
NEXT_PUBLIC_API_BASE_URL_IMAGE=http://152.42.219.13:8080

# ========================================================================
# ⚡ Performance Settings
# ========================================================================
NODE_OPTIONS=--max_old_space_size=1024
ENABLE_HOT_RELOAD=false
ENABLE_SOURCE_MAPS=false

# ========================================================================
# 🔧 Build Configuration
# ========================================================================
NEXT_TELEMETRY_DISABLED=1
ANALYZE=false

# ========================================================================
# 📊 Logging Configuration
# ========================================================================
LOG_LEVEL=info
DEBUG_MODE=false

# ========================================================================
# 🛡️ Security Configuration
# ========================================================================
SECURE_COOKIES=true
TRUST_PROXY=true

# ========================================================================
# 📱 Application URLs (for reference)
# ========================================================================
# Frontend:    http://152.42.219.13:8443
# Backend:     http://152.42.219.13:9090
# Swagger:     http://152.42.219.13:9090/swagger-ui/swagger-ui/index.html
# API Flow:    Frontend → 8443/api/* → nginx proxy → 9090/api/*
# ========================================================================